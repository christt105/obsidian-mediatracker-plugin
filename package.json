{
	"name": "media-tracker",
	"version": "1.3.1",
	"description": "Track movies, TV shows, seasons and video games in Obsidian. Data and artwork from TMDB, IGDB, Steam and SteamGridDB.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"media-tracker",
		"movies",
		"tv",
		"games",
		"tmdb",
		"igdb"
	],
	"author": "christt105",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	}
}
